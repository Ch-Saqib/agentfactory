# =============================================================================
# Lesson Shorts Generator Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8003

# -----------------------------------------------------------------------------
# Script Generation LLM Provider
# -----------------------------------------------------------------------------
# Options: groq, gemini, openai
#
# groq (Recommended for free tier):
#   - Get API key from: https://console.groq.com/keys
#   - Very generous free tier - no hard limits for development
#   - Fast inference with Llama models
#   - Set SCRIPT_PROVIDER=groq and GROQ_API_KEY below
#
# gemini:
#   - Get API key from: https://aistudio.google.com/app/apikey
#   - Used for both script generation AND Google Imagen
#   - Free tier has strict limits - requires billing for production
#   - Set SCRIPT_PROVIDER=gemini and GEMINI_API_KEY below
#
# openai:
#   - Get API key from: https://platform.openai.com/api-keys
#   - Reliable pay-as-you-go pricing
#   - Set SCRIPT_PROVIDER=openai and OPENAI_API_KEY below
SCRIPT_PROVIDER=groq

# -----------------------------------------------------------------------------
# Groq API (when SCRIPT_PROVIDER=groq) - RECOMMENDED FOR FREE TIER
# -----------------------------------------------------------------------------
# Get your API key from: https://console.groq.com/keys
# Free tier: Very generous - excellent for development and automation
GROQ_API_KEY=your-groq-api-key-here
# Models: llama-3.3-70b-versatile (best quality), llama-3.1-8b-instant (fastest)
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# Google Gemini API (when SCRIPT_PROVIDER=gemini or IMAGE_PROVIDER=imagen)
# -----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
# Note: This same API key is also used for Google Imagen (IMAGE_PROVIDER=imagen)
GEMINI_API_KEY=your-gemini-api-key-here
# Model to use for script generation (when SCRIPT_PROVIDER=gemini)
# Options:
#   - gemini-2.0-flash-lite (Recommended for free tier - 15 requests/minute)
#   - gemini-2.0-flash-exp (Good balance of speed and quality)
#   - gemini-1.5-flash (Higher free tier limits, faster but less capable)
#   - gemini-2.5-flash (Most capable but lowest free tier limits - 20/day)
GEMINI_MODEL=gemini-2.0-flash-lite

# -----------------------------------------------------------------------------
# OpenAI API (when SCRIPT_PROVIDER=openai)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
# Models: gpt-4o-mini (recommended), gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Image Generation Provider
# -----------------------------------------------------------------------------
# Options: imagen, replicate, pollinations
#
# imagen (Recommended):
#   - Uses Google Imagen API via Gemini API
#   - Cost: ~$0.03-$0.06 per image
#   - Uses your existing GEMINI_API_KEY (no additional setup!)
#   - High quality, fast generation
#
# replicate:
#   - Uses Replicate Flux Schnell model
#   - Cost: ~$0.0025 per image (cheaper)
#   - Requires REPLICATE_API_KEY below
#   - Free trial: $5 in credits
#
# pollinations (FREE):
#   - Uses Pollinations.ai free service
#   - Cost: FREE (no API key needed)
#   - Quality may vary, can be slower
#   - No setup required
IMAGE_PROVIDER=imagen

# Google Imagen Settings (when IMAGE_PROVIDER=imagen)
# Available models: imagen-3.0-generate-001, imagen-4.0-generate-001 (paid preview)
IMAGEN_MODEL=imagen-3.0-generate-001
# Aspect ratio for generated images (9:16 for vertical video)
IMAGEN_ASPECT_RATIO=9:16

# Replicate API (when IMAGE_PROVIDER=replicate)
# Get your key from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your-replicate-api-key-here
FLUX_MODEL=black-forest-labs/flux-schnell

# -----------------------------------------------------------------------------
# Edge-TTS Configuration (free, no API key needed)
# -----------------------------------------------------------------------------
# Voice to use for narration
EDGE_TTS_VOICE=en-US-AriaNeural
# Available voices: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural, etc.

# -----------------------------------------------------------------------------
# PostgreSQL Database (required for jobs, scripts, videos, engagement)
# -----------------------------------------------------------------------------
# Format: postgresql://user:password@host/database?sslmode=require
SHORTS_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage (required for video CDN)
# -----------------------------------------------------------------------------
# R2 account credentials (get from Cloudflare dashboard)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=agentfactory-shorts
# Public URL for R2 bucket (for CDN delivery)
R2_PUBLIC_URL=https://your-bucket.r2.dev
# Optional: Custom domain for CDN (e.g., cdn.example.com)
# Leave empty to use R2 direct URL
R2_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# Content API Integration (for fetching lesson content)
# -----------------------------------------------------------------------------
CONTENT_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Security & CORS
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,https://agentfactory.panaversity.org
ADMIN_SECRET=your-admin-secret-here

# -----------------------------------------------------------------------------
# Development Mode
# -----------------------------------------------------------------------------
# When true, bypasses authentication (for local development only!)
DEV_MODE=false

# Dev mode user settings (used when DEV_MODE=true)
DEV_USER_ID=dev-user-123
DEV_USER_EMAIL=dev@example.com
DEV_USER_NAME=Developer

# -----------------------------------------------------------------------------
# Cost Control & Monitoring
# -----------------------------------------------------------------------------
# Maximum cost per video in USD (default: 0.006)
MAX_COST_PER_VIDEO=0.006
# Daily budget alert threshold in USD (default: 10)
DAILY_BUDGET_ALERT=10
# Monthly budget limit in USD (default: 100)
MONTHLY_BUDGET_LIMIT=100

# -----------------------------------------------------------------------------
# Generation Settings
# -----------------------------------------------------------------------------
# Target video duration in seconds (default: 60)
TARGET_DURATION=60
# Maximum video duration in seconds (default: 90)
MAX_DURATION=90
# Number of scenes to generate (default: 3)
NUM_SCENES=3