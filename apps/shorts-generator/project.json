{
  "name": "shorts-generator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/shorts-generator/src",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator",
        "command": "uv run pytest tests/ -v --tb=short"
      },
      "cache": true,
      "inputs": ["pythonInputs"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator",
        "command": "uv run ruff check src/ tests/"
      },
      "cache": true,
      "inputs": ["pythonInputs"]
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator",
        "command": "uv run ruff format src/ tests/"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator",
        "command": "uv run ruff format --check src/ tests/"
      },
      "cache": true,
      "inputs": ["pythonInputs"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator",
        "command": "uv run mypy src/"
      },
      "cache": true,
      "inputs": ["pythonInputs"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator/src",
        "command": "uv run python -m uvicorn shorts_generator.main:app --reload --host 0.0.0.0 --port 8001 --log-level info"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator",
        "command": "docker build -t shorts-generator:latest ."
      },
      "cache": true,
      "inputs": ["pythonInputs", "{projectRoot}/Dockerfile"]
    },
    "worker": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator/src",
        "command": "uv run celery -A shorts_generator.workers.celery_worker worker --loglevel=info --pool=solo"
      }
    },
    "beat": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator/src",
        "command": "uv run celery -A shorts_generator.workers.celery_worker beat --loglevel=info"
      }
    },
    "flower": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/shorts-generator/src",
        "command": "uv run celery -A shorts_generator.workers.celery_worker flower --port=5555"
      }
    }
  }
}
