# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/learner_profiles

# SSO (required for JWT validation)
SSO_URL=http://localhost:3001

# Redis (optional - caching degrades gracefully without it)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Study Mode API (required for PHM sync)
STUDY_MODE_API_URL=http://localhost:8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Dev mode - bypasses auth for local development
DEV_MODE=false

# Debug
LOG_LEVEL=INFO
PORT=8004

# Database pool
DB_POOL_SIZE=5

# PHM settings
PHM_ALLOW_DOWNRANK=false

# GDPR
GDPR_HASH_SALT=change-me-to-a-random-string-at-least-32-chars
